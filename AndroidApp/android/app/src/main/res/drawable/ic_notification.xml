    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Center dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,10 a2,2 0 1,0 0,4 a2,2 0 1,0 0,-4 Z"/>

