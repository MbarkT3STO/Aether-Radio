# ═══════════════════════════════════════════════
#  Aether Radio Android — .gitignore
# ═══════════════════════════════════════════════

# ── Dependencies ─────────────────────────────────
node_modules/

# ── Vite build output ─────────────────────────────
dist/
dist-ssr/
.vite/
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment variables ─────────────────────────
.env
.env.local
.env.*.local

# ── OS artifacts ─────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db

# ── IDE / Editor ─────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Keystore files — NEVER commit these ──────────
*.keystore
*.jks
release.keystore

# ── Capacitor web assets (rebuilt by cap sync) ───
# These are generated by `npx cap sync` from dist/
# and must NEVER be committed — the CI always rebuilds them.
android/app/src/main/assets/public/
