# ═══════════════════════════════════════════════
#  Aether Radio — Root .gitignore
# ═══════════════════════════════════════════════

# ── OS artifacts ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────────
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── VSCode (keep shared settings, ignore personal) ──
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# ── Logs ─────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment variables ─────────────────────────
.env
.env.local
.env.*.local

# ── Misc ─────────────────────────────────────────
*.pem
.cache/
tmp/
temp/

# ── Android signing (safety net — also in AndroidApp/.gitignore) ──
*.keystore
*.jks
keystore.properties
